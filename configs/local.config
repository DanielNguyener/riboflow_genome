
// Default configuration for running the pipeline on a local machine


process {
    // if the process name is not listed separately below
    // the following settings are used
    executor='local'
    container = null   // conda env provides all tools; no container needed
    cpus = 16
    maxRetries = 1
    errorStrategy = 'retry'
    // Override the following defaults
    // by specifying the process name

    // ── Ribo-seq ──────────────────────────────────────────────────────────────
    withName: clip{
        cpus = 32
    }

    withName: filter{
        cpus = 32
    }

    withName: genome_alignment{
        cpus = 32
    }

    withName: genome_create_strand_specific_bigwigs{
        cpus = 32
    }

    // ── RNA-seq ───────────────────────────────────────────────────────────────
    withName: rnaseq_clip{
        cpus = 32
    }

    withName: rnaseq_filter{
        cpus = 32
    }

    withName: rnaseq_genome_alignment{
        cpus = 128
        memory = '110.GB'
        maxForks = 2
    }

    withName: genome_deduplicate_umicollapse{
        cpus = 4
        memory = '40.GB'
        maxForks = 4
    }

    // ── Transcriptome dedup ───────────────────────────────────────────────────
    // samtools sort is the bottleneck; 16 threads keeps BGZF decompression
    // off the critical path without over-subscribing when multiple lanes run.
    withName: transcriptome_sort_and_filter{
        cpus = 16
    }

    // samtools merge + index dominate; give them the same allocation as the
    // RNA-seq merge step so the BGZF compress/decompress stays saturated.
    withName: merge_transcriptome_qpass_bam_for_position{
        cpus = 32
    }

    withName: merge_transcriptome_bam_for_umicollapse{
        cpus = 32
    }

    // umicollapse is memory-bound, not CPU-bound; mirror genome settings.
    withName: transcriptome_deduplicate_umicollapse{
        cpus = 4
        memory = '40.GB'
        maxForks = 4
    }

    // BED operations (bamToBed, sort, rfc dedup, awk) are single-threaded;
    // samtools view/index in the split step benefit modestly from extra threads.
    withName: split_transcriptome_dedup_bam_to_individual{
        cpus = 8
    }

    withName: transcriptome_convert_dedup_bed_to_bam_position{
        cpus = 8
    }

}


// Total number of CPUs and memory reserved for nextflow
executor {
    cpus = 128
    memory = '240.GB'
}


docker {
    enabled = false
    runOptions = '-u $(id -u):$(id -g)'
}


// Default configuration for running the pipeline on a local machine.
//
// Sized for a TACC LS6 compute node (128 cores, 256 GB RAM). Adjust the
// `executor.cpus` / `executor.memory` block below for smaller workstations.
//
// IMPORTANT: `process.memory` is a forking *hint* — Nextflow ensures the
// sum of `memory` of all running tasks does not exceed `executor.memory`,
// so it won't over-subscribe forks. It does NOT enforce a cgroup limit, so
// a runaway task can still OOM the node; tuning is about making sure the
// known-heavy steps cannot run 2-at-a-time and starve each other.
//
// ── Memory accounting on a 256 GB LS6 compute node (240 GB executor budget) ──
//
// Worst-case set of concurrent forks the scheduler will allow:
//
//      process                                   mem × forks      subtotal
//      ────────────────────────────────────────────────────────────────────
//      rnaseq_genome_alignment (STAR)            120 GB × 1   =   120 GB
//      genome_deduplicate_umicollapse            40 GB × 1    =    40 GB
//      transcriptome_deduplicate_umicollapse     40 GB × 1    =    40 GB *
//      genome_create_strand_specific_bigwigs     16 GB × 2    =    32 GB
//      rnaseq_create_bigwig                      16 GB × 2    =    32 GB *
//      filter                                    16 GB × 2    =    32 GB
//      rnaseq_filter                             16 GB × 2    =    32 GB *
//      misc small forks (merges, bed ops, ...)   ≤ 16 GB
//
// (*) RNA-seq and ribo-seq don't deduplicate at the same time in practice,
//     and bigwig generation runs after dedup completes — so the *actual*
//     concurrent peak is well below the per-row sum. Nextflow's memory
//     scheduling ensures only as many forks as fit run simultaneously.
//
// All JVM-using steps (umicollapse, both flavors) are pinned to `maxForks = 1`
// because each one allocates `-Xmx32g` heap up-front; two side-by-side JVMs
// trigger `os::commit_memory(...) failed` on a node that already has STAR /
// bigwig forks resident.
//
// All bowtie2/samtools-sort filter steps and deeptools bigwig steps are
// pinned to `maxForks = 2`. The corresponding script blocks in
// `RiboFlow.groovy` also cap alignment threads at 16, samtools-sort threads
// at 8, and bamCoverage workers at 8 — so over-threading can't multiply the
// heap footprint past what `task.memory` claims.


process {
    // if the process name is not listed separately below
    // the following settings are used
    executor      = 'local'
    container     = null   // conda env provides all tools; no container needed
    cpus          = 16
    memory        = '16.GB'
    maxRetries    = 1
    errorStrategy = 'retry'
    // Override the following defaults
    // by specifying the process name

    // ── Ribo-seq ──────────────────────────────────────────────────────────────
    withName: clip{
        cpus   = 32
        memory = '16.GB'
    }

    // bowtie2 caps at 16 threads, samtools sort at 8 threads (see RiboFlow.groovy).
    // maxForks=2 prevents 4+ bowtie2+sort pipes competing for ~16 GB each on
    // a node whose free RAM has already dropped from STAR + umicollapse forks.
    withName: filter{
        cpus     = 32
        memory   = '16.GB'
        maxForks = 2
    }

    // STAR loads the human genome index entirely in RAM (~30 GB peak), plus
    // working memory for two-pass alignment. 64 GB gives comfortable headroom
    // and lets one ribo-seq lane align at a time on a 256 GB node alongside
    // RNA-seq STAR (180 GB → 120 GB elsewhere).
    withName: genome_alignment{
        cpus     = 64
        memory   = '64.GB'
        maxForks = 1
    }

    // bamCoverage forks N Python workers via multiprocessing; the script
    // already caps `-p` at min(cpus, 8). Set cpus=8 to match so the scheduler
    // can pack other small tasks alongside, and maxForks=2 keeps fork-table
    // pressure bounded across samples.
    withName: genome_create_strand_specific_bigwigs{
        cpus     = 8
        memory   = '16.GB'
        maxForks = 2
    }

    // ── RNA-seq ───────────────────────────────────────────────────────────────
    withName: rnaseq_clip{
        cpus   = 32
        memory = '16.GB'
    }

    // Same bowtie2/sort thread caps and maxForks rationale as ribo `filter`.
    withName: rnaseq_filter{
        cpus     = 32
        memory   = '16.GB'
        maxForks = 2
    }

    // RNA-seq STAR alignment is the heaviest single step. limitBAMsortRAM
    // (in rnaseq_arguments) is set to ~60 GB; STAR itself needs ~30 GB for
    // the human genome index plus 2-pass working memory. 120 GB is plenty of
    // headroom for that, and leaves room for one umicollapse JVM (40 GB) +
    // two filter forks (32 GB) + two bigwig forks (32 GB) + small ops to fit
    // within the 240 GB executor budget. maxForks=1 prevents two STAR forks
    // from doubling the RAM footprint.
    withName: rnaseq_genome_alignment{
        cpus     = 64
        memory   = '120.GB'
        maxForks = 1
    }

    // umicollapse runs `java11 -Xms512m -Xmx32g -Xss256m`. We need 32 GB heap +
    // ~8 GB JVM overhead / I/O buffers → 40 GB. maxForks=1 is critical: two
    // simultaneous `-Xmx32g` JVMs trigger `os::commit_memory(...) failed
    // (errno=12)` on a node that already has STAR + bigwig + filter forks
    // resident.
    withName: genome_deduplicate_umicollapse{
        cpus     = 8
        memory   = '40.GB'
        maxForks = 1
    }

    // ── Transcriptome dedup ───────────────────────────────────────────────────
    // samtools sort caps at 8 threads (in script); cpus=16 lets BGZF
    // decompression saturate alongside.
    withName: transcriptome_sort_and_filter{
        cpus   = 16
        memory = '32.GB'
    }

    // samtools merge + index dominate; give them the same allocation as the
    // RNA-seq merge step so the BGZF compress/decompress stays saturated.
    withName: merge_transcriptome_qpass_bam_for_position{
        cpus   = 32
        memory = '32.GB'
    }

    withName: merge_transcriptome_bam_for_umicollapse{
        cpus   = 32
        memory = '32.GB'
    }

    // Same Xmx32g rationale as genome_deduplicate_umicollapse — JVM heap +
    // overhead. maxForks=1 forbids two `-Xmx32g` JVMs from running together.
    withName: transcriptome_deduplicate_umicollapse{
        cpus     = 8
        memory   = '40.GB'
        maxForks = 1
    }

    // BED operations (bamToBed, sort, rfc dedup, awk) are single-threaded;
    // samtools view/index in the split step benefit modestly from extra threads.
    withName: split_transcriptome_dedup_bam_to_individual{
        cpus   = 8
        memory = '16.GB'
    }

    withName: transcriptome_convert_dedup_bed_to_bam_position{
        cpus   = 8
        memory = '16.GB'
    }

    // RNA-seq bigwig: see note on genome_create_strand_specific_bigwigs.
    withName: rnaseq_create_bigwig{
        cpus     = 8
        memory   = '16.GB'
        maxForks = 2
    }

}


// Total CPUs and memory the local executor may use concurrently.
// On a 256 GB LS6 node we reserve ~16 GB for the OS / Nextflow JVM and
// give 240 GB to the task pool.
//
// Sanity check (must hold): sum of (process.memory × maxForks) across the
// largest reasonable concurrent set ≤ executor.memory. See accounting table
// at the top of this file.
executor {
    cpus   = 128
    memory = '240.GB'
}


docker {
    enabled = false
    runOptions = '-u $(id -u):$(id -g)'
}

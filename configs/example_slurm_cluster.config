// Example configuration for running on a single SLURM compute node.
// Adapt cpus / memory / queue / clusterOptions to your cluster.

process {
    executor      = 'local'
    cpus          = 1
    maxRetries    = 1
    errorStrategy = 'retry'

    // Per-process overrides. Right-size these for your node.

    withName: clip                                      { cpus = 4 }
    withName: filter                                    { cpus = 8 }
    withName: genome_alignment                          { cpus = 8 }
    withName: genome_quality_filter                     { cpus = 8 }
    withName: genome_create_strand_specific_bigwigs     { cpus = 8 }

    withName: genome_deduplicate_umicollapse {
        cpus    = 4
        memory  = '20.GB'
        maxForks = 2
    }
    withName: genome_deduplicate_position               { cpus = 4 }
    withName: genome_convert_dedup_bed_to_bam_position  { cpus = 4 }

    // RNA-seq
    withName: rnaseq_clip                               { cpus = 4 }
    withName: rnaseq_filter                             { cpus = 8 }
    withName: rnaseq_genome_alignment                   { cpus = 8 }
    withName: rnaseq_genome_quality_filter              { cpus = 8 }
    withName: rnaseq_create_bigwig                      { cpus = 8 }
    withName: rnaseq_genome_deduplicate                 { cpus = 4 }
}

// Total CPUs the workflow may use concurrently on this node.
executor {
    cpus = 48
}

docker {
    enabled    = false
    runOptions = '-u $(id -u):$(id -g)'
}

// To run via the SLURM executor instead of `local`, override `process.executor`
// to 'slurm' and set `clusterOptions` (e.g. queue / partition / account).
//
// process.executor      = 'slurm'
// process.queue         = 'normal'
// process.clusterOptions = '--account=YOURPROJECT'

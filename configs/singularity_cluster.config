
// Configuration for running the pipeline on TACC LS6 (128-core nodes, 256 GB RAM)
// Submit via: sbatch tests/run_tests.sh  (or nextflow run ... -profile singularity_cluster)


process {
    executor = 'local'
    cpus = 16
    maxRetries = 1
    errorStrategy = 'retry'

    // ── Ribo-seq ──────────────────────────────────────────────────────────────
    withName: clip{
        cpus = 32
    }

    withName: filter{
        cpus = 32
    }

    withName: genome_alignment{
        cpus = 64
    }

    withName: genome_create_strand_specific_bigwigs{
        cpus = 32
    }

    // ── RNA-seq ───────────────────────────────────────────────────────────────
    withName: rnaseq_clip{
        cpus = 32
    }

    withName: rnaseq_filter{
        cpus = 32
    }

    withName: rnaseq_genome_alignment{
        cpus = 64
        memory = '110.GB'
        maxForks = 1
    }

    withName: genome_deduplicate_umicollapse{
        cpus = 4
        memory = '40.GB'
        maxForks = 4
    }

    // ── Transcriptome dedup ───────────────────────────────────────────────────
    withName: transcriptome_sort_and_filter{
        cpus = 16
    }

    withName: merge_transcriptome_qpass_bam_for_position{
        cpus = 32
    }

    withName: merge_transcriptome_bam_for_umicollapse{
        cpus = 32
    }

    withName: transcriptome_deduplicate_umicollapse{
        cpus = 4
        memory = '40.GB'
        maxForks = 4
    }

    withName: split_transcriptome_dedup_bam_to_individual{
        cpus = 8
    }

    withName: transcriptome_convert_dedup_bed_to_bam_position{
        cpus = 8
    }

}


// Total CPUs and memory available on one LS6 node
executor {
    cpus = 128
    memory = '240.GB'
}


process.container = "docker://danielnguyener/riboflow:latest"

// NF 19.04.1 only supports the `singularity` scope; Apptainer is invoked via a
// `singularity` shim on clusters that have replaced Singularity with Apptainer.
singularity {
    enabled = true
    autoMounts = true
    cacheDir = "$baseDir/image"
    runOptions = '-B /scratch:/scratch'
}

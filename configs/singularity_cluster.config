
// Configuration for running the pipeline on TACC LS6 (128-core nodes, 256 GB RAM)
// Submit via: sbatch tests/run_tests.sh  (or nextflow run ... -profile singularity_cluster)


process {
    executor = 'local'
    cpus = 16
    maxRetries = 1
    errorStrategy = 'retry'

    // ── Ribo-seq ──────────────────────────────────────────────────────────────
    withName: clip{
        cpus = 32
    }

    withName: filter{
        cpus = 32
    }

    withName: genome_alignment{
        cpus = 64
    }

    withName: genome_create_strand_specific_bigwigs{
        cpus = 32
    }

    // ── RNA-seq ───────────────────────────────────────────────────────────────
    withName: rnaseq_clip{
        cpus = 32
    }

    withName: rnaseq_filter{
        cpus = 32
    }

    withName: rnaseq_genome_alignment{
        cpus = 64
        memory = '110.GB'
        maxForks = 1
    }

    withName: genome_deduplicate_umicollapse{
        cpus = 4
        memory = '40.GB'
        maxForks = 4
    }

    // ── Transcriptome dedup ───────────────────────────────────────────────────
    withName: transcriptome_sort_and_filter{
        cpus = 16
    }

    withName: merge_transcriptome_qpass_bam_for_position{
        cpus = 32
    }

    withName: merge_transcriptome_bam_for_umicollapse{
        cpus = 32
    }

    withName: transcriptome_deduplicate_umicollapse{
        cpus = 4
        memory = '40.GB'
        maxForks = 4
    }

    withName: split_transcriptome_dedup_bam_to_individual{
        cpus = 8
    }

    withName: transcriptome_convert_dedup_bed_to_bam_position{
        cpus = 8
    }

}


// Total CPUs and memory available on one LS6 node
executor {
    cpus = 128
    memory = '240.GB'
}


process.container = "docker://danielnguyener/riboflow:latest"

// NF 19.04.1 only supports the `singularity` scope; Apptainer is invoked via a
// `singularity` shim on clusters that have replaced Singularity with Apptainer.
//
// All three apptainer directories live on $WORK (Stockyard), not $SCRATCH
// (Lustre). Reasons:
//   * loop-mounted .img containers on Lustre intermittently throw
//     "Transport endpoint is not connected" (ENOTCONN) when squashfuse loses
//     its backing under load (multiple parallel tasks against one SIF).
//   * $WORK is on a different filesystem that doesn't hit that failure mode.
//   * $HOME is too small for Docker blob caches (5 GB quota on LS6).
//   * $SCRATCH is periodically purged.
//
// We mkdir all three at config-evaluation time so a fresh checkout never has
// to remember to create them by hand before the first `nextflow run`.
def apptainerBase   = System.getenv('WORK') ?: System.getenv('HOME')
def apptainerImages = "${apptainerBase}/apptainer_images"
def apptainerCache  = "${apptainerBase}/apptainer_cache"
def apptainerTmp    = "${apptainerBase}/apptainer_tmp"
[apptainerImages, apptainerCache, apptainerTmp].each { new File(it).mkdirs() }

// Match the old riboflow branch's minimal singularity config. The container's
// own /.singularity.d/env/10-docker2singularity.sh exports the recorded
// `ENV PATH` (which already includes /miniconda3/envs/ribo_genome/bin and
// /usr/bin) at exec time; nothing here overrides it. Earlier attempts to
// inject PATH via `--env PATH=...` or `SINGULARITYENV_APPEND_PATH` either
// got stripped by NF 19.04's `env -` wrapper or got mishandled by apptainer's
// colon parsing — both modes broke the in-container memory watcher's
// awk/grep/sed/tr/ps/date lookups. Leaving PATH alone lets the image win.
singularity {
    enabled    = true
    autoMounts = true
    cacheDir   = apptainerImages
    runOptions = '-B /scratch:/scratch'
}

// Apptainer reads these env vars when it shells out to pull docker:// images.
// Setting them via NF's `env` scope guarantees they apply to NF-spawned
// apptainer pulls regardless of the caller's shell environment.
//
// (Note: SINGULARITYENV_* / APPTAINERENV_* do NOT reach `apptainer exec`
// from NF 19.04 because nxf_launch does `env -` + explicit whitelist before
// the exec. That's fine: the container's own env scripts set PATH correctly
// at startup, so we don't need to inject anything through the exec barrier.)
env {
    APPTAINER_CACHEDIR   = apptainerCache
    APPTAINER_TMPDIR     = apptainerTmp
    SINGULARITY_CACHEDIR = apptainerCache  // legacy var, some hosts still read it
    SINGULARITY_TMPDIR   = apptainerTmp
}

// Per-module storeDir / publishDir / ext settings.
//
// Directory structure:
//   {intermediates.base}/
//     clip/   filter/   umi_tools/        (preprocess — shared)
//     genome/
//       alignment/{individual,merged}     (STAR BAMs)
//       quality_filter/                   (MAPQ-filtered BAMs + counts)
//       bam_to_bed/{individual,merged}    (per-lane BED conversion)
//       alignment_ribo/{individual,merged} (dedup output)
//     transcriptome/
//       alignment/{individual,merged}     (bowtie2 BAMs)
//       quality_filter/                   (MAPQ-filtered BAMs, total count only)
//       alignment_ribo/{individual,merged} (dedup output)
//     stats/genome/{individual,merged}
//     stats/transcriptome/{individual,merged}
//
// NOTE: config directive closures run in the task context — lib/Utils.groovy is
// NOT available. Path logic is inlined using `params` only.

// Convenience macros (Groovy closures can't be defined here, so inline the pattern
// directly in each selector):
//   genome_base   = params.output?.intermediates?.base + '/genome'
//   tx_base       = params.output?.intermediates?.base + '/transcriptome'

process {

    // ── Preprocess ──────────────────────────────────────────────────────────
    withName: CUTADAPT_CLIP {
        storeDir = { new File((params.output?.intermediates?.base ?: 'intermediates'), (params.output?.intermediates ?: [:]).getOrDefault('clip', 'clip')).canonicalPath }
    }
    withName: UMITOOLS_EXTRACT {
        storeDir = { new File((params.output?.intermediates?.base ?: 'intermediates'), (params.output?.intermediates ?: [:]).getOrDefault('umi_tools', 'umi_tools')).canonicalPath + '/' + (params.output?.merged_lane_directory ?: 'merged') }
    }
    withName: BOWTIE2_FILTER {
        storeDir = { new File((params.output?.intermediates?.base ?: 'intermediates'), (params.output?.intermediates ?: [:]).getOrDefault('filter', 'filter')).canonicalPath }
    }
    withName: RAW_FASTQC {
        ext.prefix = { "${meta.id}.${meta.lane}" }
        publishDir = [ path: { new File((params.output?.output?.base ?: 'output'), (params.output?.output ?: [:]).getOrDefault('fastqc', 'fastqc')).canonicalPath + '/raw' }, mode: 'copy' ]
    }
    withName: CLIPPED_FASTQC {
        ext.prefix = { "${meta.id}.${meta.lane}.clipped" }
        publishDir = [ path: { new File((params.output?.output?.base ?: 'output'), (params.output?.output ?: [:]).getOrDefault('fastqc', 'fastqc')).canonicalPath + '/clipped' }, mode: 'copy' ]
    }
    withName: GENOME_ALIGNED_FASTQC {
        ext.prefix = { "${meta.id}.${meta.lane}.genome.aligned" }
        publishDir = [ path: { new File((params.output?.output?.base ?: 'output'), (params.output?.output ?: [:]).getOrDefault('fastqc', 'fastqc')).canonicalPath + '/genome_aligned' }, mode: 'copy' ]
    }
    withName: GENOME_UNALIGNED_FASTQC {
        ext.prefix = { "${meta.id}.${meta.lane}.genome.unaligned" }
        publishDir = [ path: { new File((params.output?.output?.base ?: 'output'), (params.output?.output ?: [:]).getOrDefault('fastqc', 'fastqc')).canonicalPath + '/genome_unaligned' }, mode: 'copy' ]
    }

    // ── STAR index generation (build-from-FASTA mode) ───────────────────────
    // storeDir: use star.index_dir if set (persistent across runs), otherwise
    // fall back to intermediates/star_index. storeDir caching means the index
    // is only built once; subsequent runs skip STAR_INDEX entirely.
    withName: STAR_INDEX {
        storeDir = {
            def d = params.star?.getOrDefault('index_dir', null)
            d ? new File(d).canonicalPath
              : new File((params.output?.intermediates?.base ?: 'intermediates'), 'star_index').canonicalPath
        }
        ext.sjdb_overhang = { params.star?.getOrDefault('sjdb_overhang', 100) }
    }

    // ── Genome alignment ──────────────────────────────────────────────────────
    withName: STAR_ALIGN {
        storeDir = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/genome', 'alignment').canonicalPath + '/' + (params.output?.individual_lane_directory ?: 'individual') }
    }
    withName: '.*:GENOME_ALIGN:SAMTOOLS_QPASS' {
        ext.prefix       = { "${meta.id}.${meta.lane}.genome_alignment" }
        ext.count_unique = true
        storeDir         = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/genome', 'quality_filter').canonicalPath }
    }
    withName: '.*:GENOME_ALIGN:BAM_TO_BED' {
        ext.prefix = { "${meta.id}.${meta.lane}.genome.qpass" }
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/genome', 'bam_to_bed').canonicalPath + '/' + (params.output?.individual_lane_directory ?: 'individual') }
        publishDir = [ path: { new File((params.output?.output?.base ?: 'output'), (params.output?.output ?: [:]).getOrDefault('alignments', 'alignments')).canonicalPath + '/ribo/' + (params.output?.individual_lane_directory ?: 'individual') },
                       mode: 'copy', enabled: { (params.dedup_method ?: 'none').toString().toLowerCase() == 'none' && (params.deduplicate ?: false).toString().toLowerCase() == 'false' } ]
    }
    withName: '.*:GENOME_ALIGN:SAMTOOLS_MERGE' {
        ext.prefix = { "${meta.id}.genome.qpass.merged" }
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/genome', 'alignment').canonicalPath + '/' + (params.output?.merged_lane_directory ?: 'merged') }
        publishDir = [ path: { new File((params.output?.output?.base ?: 'output'), (params.output?.output ?: [:]).getOrDefault('alignments', 'alignments')).canonicalPath + '/ribo/' + (params.output?.merged_lane_directory ?: 'merged') },
                       mode: 'copy', enabled: { (params.dedup_method ?: 'none').toString().toLowerCase() == 'none' && (params.deduplicate ?: false).toString().toLowerCase() == 'false' } ]
    }

    // ── Position dedup (genome) ───────────────────────────────────────────────
    withName: ADD_SAMPLE_INDEX_COL {
        storeDir = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/genome', 'bam_to_bed').canonicalPath + '/' + (params.output?.individual_lane_directory ?: 'individual') }
    }
    withName: MERGE_PRE_DEDUP_BED {
        ext.prefix = { "${meta.id}.genome.merged.pre_dedup" }
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/genome', 'bam_to_bed').canonicalPath + '/' + (params.output?.merged_lane_directory ?: 'merged') }
    }
    withName: '.*:GENOME_ALIGN:RFC_DEDUP' {
        ext.prefix = { "${meta.id}.genome" }
        storeDir   = { new File((params.output?.output?.base ?: 'output'), (params.output?.output ?: [:]).getOrDefault('alignments', 'alignments')).canonicalPath + '/ribo/' + (params.output?.merged_lane_directory ?: 'merged') }
    }
    withName: '.*:GENOME_ALIGN:SEPARATE_BED' {
        ext.prefix           = { "${meta.id}.${meta.lane}.genome" }
        ext.emit_counts      = true
        ext.emit_full_counts = { (params.genome?.mapping_quality_cutoff as int ?: 255) < 255 }
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/genome', 'alignment_ribo').canonicalPath + '/' + (params.output?.individual_lane_directory ?: 'individual') }
        publishDir = [ path: { new File((params.output?.output?.base ?: 'output'), (params.output?.output ?: [:]).getOrDefault('alignments', 'alignments')).canonicalPath + '/ribo/' + (params.output?.individual_lane_directory ?: 'individual') },
                       mode: 'copy', saveAs: { fn -> fn.endsWith('.count') ? null : fn } ]
    }
    withName: '.*:GENOME_ALIGN:RFC_EXTRACT_DEDUP_READS' {
        ext.prefix           = { "${meta.id}.post_dedup" }
        ext.emit_counts      = true
        ext.emit_full_counts = { (params.genome?.mapping_quality_cutoff as int ?: 255) < 255 }
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/genome', 'alignment_ribo').canonicalPath + '/' + (params.output?.merged_lane_directory ?: 'merged') }
        publishDir = [ path: { new File((params.output?.output?.base ?: 'output'), (params.output?.output ?: [:]).getOrDefault('alignments', 'alignments')).canonicalPath + '/ribo/' + (params.output?.merged_lane_directory ?: 'merged') },
                       mode: 'copy', saveAs: { fn -> fn.endsWith('.count') ? null : fn } ]
    }

    // ── umicollapse dedup (genome) ────────────────────────────────────────────
    withName: '.*:GENOME_ALIGN:UMICOLLAPSE_DEDUP' {
        ext.prefix           = { "${meta.id}.dedup" }
        ext.emit_counts      = true
        ext.emit_full_counts = { (params.genome?.mapping_quality_cutoff as int ?: 255) < 255 }
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/genome', 'alignment_ribo').canonicalPath + '/' + (params.output?.merged_lane_directory ?: 'merged') }
        publishDir = [ path: { new File((params.output?.output?.base ?: 'output'), (params.output?.output ?: [:]).getOrDefault('alignments', 'alignments')).canonicalPath + '/ribo/' + (params.output?.merged_lane_directory ?: 'merged') },
                       mode: 'copy', saveAs: { fn -> fn.endsWith('.count') ? null : fn } ]
    }
    withName: '.*:GENOME_ALIGN:SPLIT_DEDUP_BAM' {
        ext.prefix           = { "${meta.id}.${meta.lane}.post_dedup" }
        ext.emit_bed_counts  = true
        ext.emit_full_counts = { (params.genome?.mapping_quality_cutoff as int ?: 255) < 255 }
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/genome', 'alignment_ribo').canonicalPath + '/' + (params.output?.individual_lane_directory ?: 'individual') }
        publishDir = [ path: { new File((params.output?.output?.base ?: 'output'), (params.output?.output ?: [:]).getOrDefault('alignments', 'alignments')).canonicalPath + '/ribo/' + (params.output?.individual_lane_directory ?: 'individual') },
                       mode: 'copy', saveAs: { fn -> fn.endsWith('.count') ? null : fn } ]
    }
    withName: CONCAT_POST_DEDUP_BED {
        ext.prefix = { "${meta.id}.genome.post_dedup" }
        storeDir   = { new File((params.output?.output?.base ?: 'output'), (params.output?.output ?: [:]).getOrDefault('alignments', 'alignments')).canonicalPath + '/ribo/' + (params.output?.merged_lane_directory ?: 'merged') }
    }

    // ── none: publish merged qpass BED ────────────────────────────────────────
    withName: CONCAT_QPASS_BED_NONE {
        ext.prefix = { "${meta.id}.genome.qpass" }
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/genome', 'bam_to_bed').canonicalPath + '/' + (params.output?.merged_lane_directory ?: 'merged') }
        publishDir = [ path: { new File((params.output?.output?.base ?: 'output'), (params.output?.output ?: [:]).getOrDefault('alignments', 'alignments')).canonicalPath + '/ribo/' + (params.output?.merged_lane_directory ?: 'merged') },
                       mode: 'copy' ]
    }

    // ── bigwig + stranded split ───────────────────────────────────────────────
    withName: DEEPTOOLS_BAMCOVERAGE {
        storeDir = { new File((params.output?.output?.base ?: 'output'), (params.output?.output ?: [:]).getOrDefault('bigwigs', 'bigwigs')).canonicalPath + '/ribo' }
    }
    withName: SPLIT_STRANDED_BAM {
        storeDir = { new File((params.output?.output?.base ?: 'output'), (params.output?.output ?: [:]).getOrDefault('alignments', 'alignments')).canonicalPath + '/ribo/stranded' }
    }

    // ── Genome stats ──────────────────────────────────────────────────────────
    withName: '.*:ALIGNMENT_STATS:STATS_INDIVIDUAL' {
        ext.stats_label = 'genome'
        ext.unique_only = { (params.genome.mapping_quality_cutoff as int) >= 255 }
        storeDir = { new File((params.output?.intermediates?.base ?: 'intermediates'), (params.output?.intermediates ?: [:]).getOrDefault('stats', 'stats')).canonicalPath + '/genome/individual' }
    }
    withName: '.*:ALIGNMENT_STATS:COMBINE_INDIVIDUAL' {
        ext.prefix      = 'genome_individual_essential'
        ext.unique_only = { (params.genome.mapping_quality_cutoff as int) >= 255 }
        storeDir        = { new File((params.output?.intermediates?.base ?: 'intermediates'), (params.output?.intermediates ?: [:]).getOrDefault('stats', 'stats')).canonicalPath + '/genome/individual' }
    }
    withName: '.*:ALIGNMENT_STATS:STATS_SUM' {
        ext.label             = 'genome'
        ext.use_merged_counts = { !((params.dedup_method ?: 'none').toString().toLowerCase() == 'none' && (params.deduplicate ?: false).toString().toLowerCase() == 'false') }
        ext.unique_only       = { (params.genome.mapping_quality_cutoff as int) >= 255 }
        storeDir = { new File((params.output?.intermediates?.base ?: 'intermediates'), (params.output?.intermediates ?: [:]).getOrDefault('stats', 'stats')).canonicalPath + '/genome/merged' }
    }
    withName: '.*:ALIGNMENT_STATS:COMBINE_MERGED' {
        ext.prefix      = 'genome_merged_essential'
        ext.unique_only = { (params.genome.mapping_quality_cutoff as int) >= 255 }
        storeDir        = { new File((params.output?.intermediates?.base ?: 'intermediates'), (params.output?.intermediates ?: [:]).getOrDefault('stats', 'stats')).canonicalPath + '/genome/merged' }
    }
    withName: '.*:ALIGNMENT_STATS:STATS_PUBLISH' {
        publishDir = [ path: { new File((params.output?.output?.base ?: 'output'), (params.output?.output ?: [:]).getOrDefault('stats', 'stats')).canonicalPath + '/genome' }, mode: 'copy' ]
    }
    withName: WRITE_CORRESPONDENCE {
        publishDir = [ path: { new File((params.output?.output?.base ?: 'output'), (params.output?.output ?: [:]).getOrDefault('stats', 'stats')).canonicalPath }, mode: 'copy' ]
    }

    // ── Transcriptome stats ───────────────────────────────────────────────────
    withName: '.*:TRANSCRIPTOME_STATS:TX_STATS_INDIVIDUAL' {
        storeDir = { new File((params.output?.intermediates?.base ?: 'intermediates'), (params.output?.intermediates ?: [:]).getOrDefault('stats', 'stats')).canonicalPath + '/transcriptome/individual' }
    }
    withName: '.*:TRANSCRIPTOME_STATS:TX_COMBINE_INDIVIDUAL' {
        ext.prefix      = 'transcriptome_individual_essential'
        ext.stats_label = 'transcriptome'
        storeDir        = { new File((params.output?.intermediates?.base ?: 'intermediates'), (params.output?.intermediates ?: [:]).getOrDefault('stats', 'stats')).canonicalPath + '/transcriptome/individual' }
    }
    withName: '.*:TRANSCRIPTOME_STATS:TX_STATS_SUM' {
        ext.label             = 'transcriptome'
        ext.use_merged_counts = false
        storeDir = { new File((params.output?.intermediates?.base ?: 'intermediates'), (params.output?.intermediates ?: [:]).getOrDefault('stats', 'stats')).canonicalPath + '/transcriptome/merged' }
    }
    withName: '.*:TRANSCRIPTOME_STATS:TX_COMBINE_MERGED' {
        ext.prefix      = 'transcriptome_merged_essential'
        ext.stats_label = 'transcriptome'
        storeDir        = { new File((params.output?.intermediates?.base ?: 'intermediates'), (params.output?.intermediates ?: [:]).getOrDefault('stats', 'stats')).canonicalPath + '/transcriptome/merged' }
    }
    withName: '.*:TRANSCRIPTOME_STATS:TX_STATS_PUBLISH' {
        publishDir = [ path: { new File((params.output?.output?.base ?: 'output'), (params.output?.output ?: [:]).getOrDefault('stats', 'stats')).canonicalPath + '/transcriptome' }, mode: 'copy' ]
    }

    // ── Optional transcriptome dedup subworkflow (STAR tx-projected BAM/BED only) ──
    withName: '.*:STAR_TRANSCRIPTOME_DEDUP:SAMTOOLS_QPASS' {
        ext.prefix  = { "${meta.id}.${meta.lane}.transcriptome_alignment" }
        ext.presort = true
        storeDir    = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/transcriptome', 'quality_filter').canonicalPath + '/' + (params.output?.individual_lane_directory ?: 'individual') }
    }
    withName: '.*:STAR_TRANSCRIPTOME_DEDUP:BAM_TO_BED' {
        ext.prefix       = { "${meta.id}.${meta.lane}.transcriptome.with_sample_index" }
        ext.append_index = true
        storeDir         = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/transcriptome', 'quality_filter').canonicalPath + '/' + (params.output?.individual_lane_directory ?: 'individual') }
    }
    withName: '.*:STAR_TRANSCRIPTOME_DEDUP:CONCAT_SORT_BED' {
        ext.prefix = { "${meta.id}.transcriptome.merged.pre_dedup" }
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/transcriptome', 'alignment_ribo').canonicalPath + '/' + (params.output?.merged_lane_directory ?: 'merged') }
    }
    withName: '.*:STAR_TRANSCRIPTOME_DEDUP:RFC_DEDUP' {
        ext.prefix = { "${meta.id}.transcriptome" }
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/transcriptome', 'alignment_ribo').canonicalPath + '/' + (params.output?.merged_lane_directory ?: 'merged') }
    }
    withName: '.*:STAR_TRANSCRIPTOME_DEDUP:SEPARATE_BED' {
        ext.prefix = { "${meta.id}.${meta.lane}.transcriptome" }
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/transcriptome', 'alignment_ribo').canonicalPath + '/' + (params.output?.individual_lane_directory ?: 'individual') }
    }
    withName: '.*:STAR_TRANSCRIPTOME_DEDUP:SAMTOOLS_MERGE' {
        ext.prefix = { "${meta.id}.transcriptome.qpass.merged" }
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/transcriptome', 'alignment').canonicalPath + '/' + (params.output?.merged_lane_directory ?: 'merged') }
    }
    withName: '.*:STAR_TRANSCRIPTOME_DEDUP:RFC_EXTRACT_DEDUP_READS' {
        ext.prefix = { "${meta.id}.transcriptome.post_dedup" }
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/transcriptome', 'alignment_ribo').canonicalPath + '/' + (params.output?.merged_lane_directory ?: 'merged') }
    }
    withName: '.*:STAR_TRANSCRIPTOME_DEDUP:UMICOLLAPSE_DEDUP' {
        ext.prefix = { "${meta.id}.transcriptome.dedup" }
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/transcriptome', 'alignment_ribo').canonicalPath + '/' + (params.output?.merged_lane_directory ?: 'merged') }
    }
    withName: '.*:STAR_TRANSCRIPTOME_DEDUP:SPLIT_DEDUP_BAM' {
        ext.prefix = { "${meta.id}.${meta.lane}.transcriptome.post_dedup" }
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/transcriptome', 'alignment_ribo').canonicalPath + '/' + (params.output?.merged_lane_directory ?: 'merged') }
    }

    // ── Bowtie2 transcriptome alignment → ribopy create (.ribo) ──────────────
    withName: '.*:TRANSCRIPTOME_ALIGN:BOWTIE2_TRANSCRIPTOME' {
        storeDir = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/transcriptome', 'alignment').canonicalPath + '/' + (params.output?.individual_lane_directory ?: 'individual') }
    }
    withName: '.*:TRANSCRIPTOME_ALIGN:SAMTOOLS_QPASS' {
        ext.prefix              = { "${meta.id}.${meta.lane}.transcriptome_alignment" }
        ext.presort             = false
        ext.mapq                = { (params.transcriptome?.mapping_quality_cutoff != null) ? params.transcriptome.mapping_quality_cutoff : 10 }
        ext.emit_primary_secondary = false
        storeDir                = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/transcriptome', 'quality_filter').canonicalPath }
    }
    withName: '.*:TRANSCRIPTOME_ALIGN:SAMTOOLS_MERGE' {
        ext.prefix = { "${meta.id}.transcriptome.qpass.merged" }
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/transcriptome', 'alignment').canonicalPath + '/' + (params.output?.merged_lane_directory ?: 'merged') }
    }
    withName: '.*:TRANSCRIPTOME_ALIGN:TX_QPASS_BAM_TO_BED' {
        ext.prefix       = { "${meta.id}.${meta.lane}.transcriptome.with_sample_index" }
        ext.append_index = true
        storeDir         = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/transcriptome', 'quality_filter').canonicalPath }
    }
    withName: '.*:TRANSCRIPTOME_ALIGN:TX_MERGED_QPASS_BED' {
        ext.prefix = { "${meta.id}.transcriptome.qpass.merged" }
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/transcriptome', 'alignment_ribo').canonicalPath + '/' + (params.output?.merged_lane_directory ?: 'merged') }
    }
    withName: '.*:TRANSCRIPTOME_ALIGN:TX_MERGED_DEDUP_BED' {
        ext.prefix = { "${meta.id}.transcriptome.dedup" }
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/transcriptome', 'alignment_ribo').canonicalPath + '/' + (params.output?.merged_lane_directory ?: 'merged') }
    }
    withName: '.*:TRANSCRIPTOME_ALIGN:MERGE_TX_PRE_DEDUP_BED' {
        ext.prefix = { "${meta.id}.transcriptome.merged.pre_dedup" }
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/transcriptome', 'alignment_ribo').canonicalPath + '/' + (params.output?.merged_lane_directory ?: 'merged') }
    }
    withName: '.*:TRANSCRIPTOME_ALIGN:RFC_DEDUP' {
        ext.prefix = { "${meta.id}.transcriptome" }
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/transcriptome', 'alignment_ribo').canonicalPath + '/' + (params.output?.merged_lane_directory ?: 'merged') }
    }
    withName: '.*:TRANSCRIPTOME_ALIGN:SEPARATE_BED' {
        ext.prefix           = { "${meta.id}.${meta.lane}.transcriptome" }
        ext.emit_counts      = true
        ext.emit_full_counts = false  // tx stats need total only; skip sort-u primary/secondary/unique
        storeDir        = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/transcriptome', 'alignment_ribo').canonicalPath + '/' + (params.output?.individual_lane_directory ?: 'individual') }
    }
    withName: '.*:TRANSCRIPTOME_ALIGN:RFC_EXTRACT_DEDUP_READS' {
        ext.prefix      = { "${meta.id}.transcriptome.post_dedup" }
        ext.emit_counts = false  // merged-level counts not consumed by tx stats
        storeDir        = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/transcriptome', 'alignment_ribo').canonicalPath + '/' + (params.output?.merged_lane_directory ?: 'merged') }
    }
    withName: '.*:TRANSCRIPTOME_ALIGN:UMICOLLAPSE_DEDUP' {
        ext.prefix      = { "${meta.id}.transcriptome.dedup" }
        ext.emit_counts = false  // merged-level counts not consumed by tx stats
        storeDir        = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/transcriptome', 'alignment_ribo').canonicalPath + '/' + (params.output?.merged_lane_directory ?: 'merged') }
    }
    withName: '.*:TRANSCRIPTOME_ALIGN:SPLIT_DEDUP_BAM' {
        ext.prefix           = { "${meta.id}.${meta.lane}.transcriptome.post_dedup" }
        ext.emit_bed_counts  = true
        ext.emit_full_counts = false
        storeDir            = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/transcriptome', 'alignment_ribo').canonicalPath + '/' + (params.output?.individual_lane_directory ?: 'individual') }
    }
    withName: 'RIBOPY_CREATE' {
        storeDir = { new File((params.output?.output?.base ?: 'output'), (params.output?.output ?: [:]).getOrDefault('ribo', 'ribo')).canonicalPath }
    }

    // ════════════════════════════════════════════════════════════════════════════
    //  RNA-seq path
    //  ext.mapq / ext.filter_flags / ext.unique_only are CLOSURES (lazy) and use a
    //  fallback chain so both nested (rnaseq.genome.*) and flat (rnaseq.*) YAML
    //  shapes work. Output dirs are separated under rnaseq/ to avoid collisions.
    // ════════════════════════════════════════════════════════════════════════════

    // ── RNA-seq preprocess ────────────────────────────────────────────────────────
    withName: CUTADAPT_CLIP_RNASEQ {
        storeDir = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/rnaseq', 'clip').canonicalPath }
    }
    withName: BOWTIE2_FILTER_RNASEQ {
        storeDir = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/rnaseq', 'filter').canonicalPath }
    }

    // ── RNA-seq genome alignment ─────────────────────────────────────────────────
    withName: STAR_ALIGN_RNASEQ {
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/rnaseq/genome', 'alignment').canonicalPath + '/' + (params.output?.individual_lane_directory ?: 'individual') }
        publishDir = [ path: { new File((params.output?.intermediates?.base ?: 'intermediates') + '/rnaseq', 'stats').canonicalPath + '/genome/individual' },
                       mode: 'copy', saveAs: { fn -> fn.endsWith('.log') ? fn : null } ]
    }
    withName: '.*:RNASEQ_GENOME_ALIGN:SAMTOOLS_QPASS' {
        ext.prefix               = { "${meta.id}.${meta.lane}.rnaseq.genome_alignment" }
        ext.emit_primary_secondary = { ((params.rnaseq?.genome?.mapping_quality_cutoff ?: params.rnaseq?.mapping_quality_cutoff ?: 4) as int) == 0 }
        ext.count_unique           = { ((params.rnaseq?.genome?.mapping_quality_cutoff ?: params.rnaseq?.mapping_quality_cutoff ?: 4) as int) == 0 }
        ext.filter_flags         = { (params.rnaseq?.genome?.filter_flags ?: params.rnaseq?.filter_flags ?: 2308) }
        ext.mapq                 = { (params.rnaseq?.genome?.mapping_quality_cutoff ?: params.rnaseq?.mapping_quality_cutoff ?: 4) }
        storeDir                 = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/rnaseq/genome', 'quality_filter').canonicalPath }
    }
    withName: '.*:RNASEQ_GENOME_ALIGN:BAM_TO_BED' {
        ext.prefix = { "${meta.id}.${meta.lane}.rnaseq.genome.qpass" }
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/rnaseq/genome', 'bam_to_bed').canonicalPath + '/' + (params.output?.individual_lane_directory ?: 'individual') }
        publishDir = [ path: { new File((params.output?.output?.base ?: 'output') + '/rnaseq', (params.output?.output ?: [:]).getOrDefault('alignments', 'alignments')).canonicalPath + '/genome/' + (params.output?.individual_lane_directory ?: 'individual') },
                       mode: 'copy', enabled: { (params.rnaseq?.dedup_method ?: 'none').toString().toLowerCase() == 'none' } ]
    }
    withName: '.*:RNASEQ_GENOME_ALIGN:SAMTOOLS_MERGE' {
        ext.prefix = { "${meta.id}.rnaseq.genome.qpass.merged" }
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/rnaseq/genome', 'alignment').canonicalPath + '/' + (params.output?.merged_lane_directory ?: 'merged') }
        publishDir = [ path: { new File((params.output?.output?.base ?: 'output') + '/rnaseq', (params.output?.output ?: [:]).getOrDefault('alignments', 'alignments')).canonicalPath + '/genome/' + (params.output?.merged_lane_directory ?: 'merged') },
                       mode: 'copy', enabled: { (params.rnaseq?.dedup_method ?: 'none').toString().toLowerCase() == 'none' } ]
    }
    withName: '.*:RNASEQ_GENOME_ALIGN:ADD_SAMPLE_INDEX_COL' {
        storeDir = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/rnaseq/genome', 'bam_to_bed').canonicalPath + '/' + (params.output?.individual_lane_directory ?: 'individual') }
    }
    withName: 'RNASEQ_MERGE_PRE_DEDUP_BED' {
        ext.prefix = { "${meta.id}.rnaseq.genome.merged.pre_dedup" }
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/rnaseq/genome', 'bam_to_bed').canonicalPath + '/' + (params.output?.merged_lane_directory ?: 'merged') }
    }
    withName: '.*:RNASEQ_GENOME_ALIGN:RFC_DEDUP' {
        ext.prefix = { "${meta.id}.rnaseq.genome" }
        storeDir   = { new File((params.output?.output?.base ?: 'output') + '/rnaseq', (params.output?.output ?: [:]).getOrDefault('alignments', 'alignments')).canonicalPath + '/genome/' + (params.output?.merged_lane_directory ?: 'merged') }
    }
    withName: '.*:RNASEQ_GENOME_ALIGN:SEPARATE_BED' {
        ext.prefix           = { "${meta.id}.${meta.lane}.rnaseq.genome" }
        ext.emit_counts      = true
        ext.emit_full_counts = { ((params.rnaseq?.genome?.mapping_quality_cutoff ?: params.rnaseq?.mapping_quality_cutoff ?: 4) as int) == 0 }
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/rnaseq/genome', 'alignment_ribo').canonicalPath + '/' + (params.output?.individual_lane_directory ?: 'individual') }
        publishDir = [ path: { new File((params.output?.output?.base ?: 'output') + '/rnaseq', (params.output?.output ?: [:]).getOrDefault('alignments', 'alignments')).canonicalPath + '/genome/' + (params.output?.individual_lane_directory ?: 'individual') },
                       mode: 'copy', saveAs: { fn -> fn.endsWith('.count') ? null : fn } ]
    }
    withName: '.*:RNASEQ_GENOME_ALIGN:RFC_EXTRACT_DEDUP_READS' {
        ext.prefix           = { "${meta.id}.rnaseq.post_dedup" }
        ext.emit_counts      = true
        ext.emit_full_counts = { ((params.rnaseq?.genome?.mapping_quality_cutoff ?: params.rnaseq?.mapping_quality_cutoff ?: 4) as int) == 0 }
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/rnaseq/genome', 'alignment_ribo').canonicalPath + '/' + (params.output?.merged_lane_directory ?: 'merged') }
        publishDir = [ path: { new File((params.output?.output?.base ?: 'output') + '/rnaseq', (params.output?.output ?: [:]).getOrDefault('alignments', 'alignments')).canonicalPath + '/genome/' + (params.output?.merged_lane_directory ?: 'merged') },
                       mode: 'copy', saveAs: { fn -> fn.endsWith('.count') ? null : fn } ]
    }
    withName: '.*:RNASEQ_GENOME_ALIGN:UMICOLLAPSE_DEDUP' {
        ext.prefix           = { "${meta.id}.rnaseq.dedup" }
        ext.emit_counts      = true
        ext.emit_full_counts = { ((params.rnaseq?.genome?.mapping_quality_cutoff ?: params.rnaseq?.mapping_quality_cutoff ?: 4) as int) == 0 }
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/rnaseq/genome', 'alignment_ribo').canonicalPath + '/' + (params.output?.merged_lane_directory ?: 'merged') }
        publishDir = [ path: { new File((params.output?.output?.base ?: 'output') + '/rnaseq', (params.output?.output ?: [:]).getOrDefault('alignments', 'alignments')).canonicalPath + '/genome/' + (params.output?.merged_lane_directory ?: 'merged') },
                       mode: 'copy', saveAs: { fn -> fn.endsWith('.count') ? null : fn } ]
    }
    withName: '.*:RNASEQ_GENOME_ALIGN:SPLIT_DEDUP_BAM' {
        ext.prefix           = { "${meta.id}.${meta.lane}.rnaseq.post_dedup" }
        ext.emit_bed_counts  = true
        ext.emit_full_counts = { ((params.rnaseq?.genome?.mapping_quality_cutoff ?: params.rnaseq?.mapping_quality_cutoff ?: 4) as int) == 0 }
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/rnaseq/genome', 'alignment_ribo').canonicalPath + '/' + (params.output?.individual_lane_directory ?: 'individual') }
        publishDir = [ path: { new File((params.output?.output?.base ?: 'output') + '/rnaseq', (params.output?.output ?: [:]).getOrDefault('alignments', 'alignments')).canonicalPath + '/genome/' + (params.output?.individual_lane_directory ?: 'individual') },
                       mode: 'copy', saveAs: { fn -> fn.endsWith('.count') ? null : fn } ]
    }
    withName: 'RNASEQ_CONCAT_QPASS_BED_NONE' {
        ext.prefix = { "${meta.id}.rnaseq.genome.qpass" }
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/rnaseq/genome', 'bam_to_bed').canonicalPath + '/' + (params.output?.merged_lane_directory ?: 'merged') }
        publishDir = [ path: { new File((params.output?.output?.base ?: 'output') + '/rnaseq', (params.output?.output ?: [:]).getOrDefault('alignments', 'alignments')).canonicalPath + '/genome/' + (params.output?.merged_lane_directory ?: 'merged') },
                       mode: 'copy' ]
    }
    withName: 'RNASEQ_CONCAT_POST_DEDUP_BED' {
        ext.prefix = { "${meta.id}.rnaseq.genome.post_dedup" }
        storeDir   = { new File((params.output?.output?.base ?: 'output') + '/rnaseq', (params.output?.output ?: [:]).getOrDefault('alignments', 'alignments')).canonicalPath + '/genome/' + (params.output?.merged_lane_directory ?: 'merged') }
    }
    withName: '.*:RNASEQ_GENOME_ALIGN:DEEPTOOLS_BAMCOVERAGE' {
        storeDir = { new File((params.output?.output?.base ?: 'output') + '/rnaseq', (params.output?.output ?: [:]).getOrDefault('bigwigs', 'bigwigs')).canonicalPath + '/genome' }
    }

    // ── RNA-seq transcriptome alignment ──────────────────────────────────────────
    withName: BOWTIE2_TRANSCRIPTOME_RNASEQ {
        storeDir = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/rnaseq/transcriptome', 'alignment').canonicalPath + '/' + (params.output?.individual_lane_directory ?: 'individual') }
    }
    withName: '.*:RNASEQ_TRANSCRIPTOME_ALIGN:SAMTOOLS_QPASS' {
        ext.prefix                 = { "${meta.id}.${meta.lane}.rnaseq.transcriptome_alignment" }
        ext.presort                = false
        ext.emit_primary_secondary = false
        ext.filter_flags           = { (params.rnaseq?.genome?.filter_flags ?: params.rnaseq?.filter_flags ?: 2308) }
        ext.mapq                   = { (params.rnaseq?.transcriptome?.mapping_quality_cutoff ?: 10) }
        storeDir                   = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/rnaseq/transcriptome', 'quality_filter').canonicalPath }
    }
    withName: '.*:RNASEQ_TRANSCRIPTOME_ALIGN:SAMTOOLS_MERGE' {
        ext.prefix = { "${meta.id}.rnaseq.transcriptome.qpass.merged" }
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/rnaseq/transcriptome', 'alignment').canonicalPath + '/' + (params.output?.merged_lane_directory ?: 'merged') }
    }
    withName: '.*:RNASEQ_TRANSCRIPTOME_ALIGN:RNASEQ_TX_QPASS_BAM_TO_BED' {
        ext.prefix       = { "${meta.id}.${meta.lane}.rnaseq.transcriptome.with_sample_index" }
        ext.append_index = true
        storeDir         = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/rnaseq/transcriptome', 'quality_filter').canonicalPath }
    }
    withName: '.*:RNASEQ_TRANSCRIPTOME_ALIGN:RNASEQ_TX_MERGED_QPASS_BED' {
        ext.prefix = { "${meta.id}.rnaseq.transcriptome.qpass.merged" }
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/rnaseq/transcriptome', 'alignment_ribo').canonicalPath + '/' + (params.output?.merged_lane_directory ?: 'merged') }
    }
    withName: '.*:RNASEQ_TRANSCRIPTOME_ALIGN:RNASEQ_TX_MERGED_DEDUP_BED' {
        ext.prefix = { "${meta.id}.rnaseq.transcriptome.dedup" }
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/rnaseq/transcriptome', 'alignment_ribo').canonicalPath + '/' + (params.output?.merged_lane_directory ?: 'merged') }
    }
    withName: 'RNASEQ_MERGE_TX_PRE_DEDUP_BED' {
        ext.prefix = { "${meta.id}.rnaseq.transcriptome.merged.pre_dedup" }
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/rnaseq/transcriptome', 'alignment_ribo').canonicalPath + '/' + (params.output?.merged_lane_directory ?: 'merged') }
    }
    withName: '.*:RNASEQ_TRANSCRIPTOME_ALIGN:RFC_DEDUP' {
        ext.prefix = { "${meta.id}.rnaseq.transcriptome" }
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/rnaseq/transcriptome', 'alignment_ribo').canonicalPath + '/' + (params.output?.merged_lane_directory ?: 'merged') }
    }
    withName: '.*:RNASEQ_TRANSCRIPTOME_ALIGN:SEPARATE_BED' {
        ext.prefix           = { "${meta.id}.${meta.lane}.rnaseq.transcriptome" }
        ext.emit_counts      = true
        ext.emit_full_counts = false
        storeDir        = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/rnaseq/transcriptome', 'alignment_ribo').canonicalPath + '/' + (params.output?.individual_lane_directory ?: 'individual') }
    }
    withName: '.*:RNASEQ_TRANSCRIPTOME_ALIGN:RFC_EXTRACT_DEDUP_READS' {
        ext.prefix      = { "${meta.id}.rnaseq.transcriptome.post_dedup" }
        ext.emit_counts = false  // merged-level counts not consumed by rnaseq tx stats
        storeDir        = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/rnaseq/transcriptome', 'alignment_ribo').canonicalPath + '/' + (params.output?.merged_lane_directory ?: 'merged') }
    }
    withName: '.*:RNASEQ_TRANSCRIPTOME_ALIGN:UMICOLLAPSE_DEDUP' {
        ext.prefix      = { "${meta.id}.rnaseq.transcriptome.dedup" }
        ext.emit_counts = false  // merged-level counts not consumed by rnaseq tx stats
        storeDir        = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/rnaseq/transcriptome', 'alignment_ribo').canonicalPath + '/' + (params.output?.merged_lane_directory ?: 'merged') }
    }
    withName: '.*:RNASEQ_TRANSCRIPTOME_ALIGN:SPLIT_DEDUP_BAM' {
        ext.prefix           = { "${meta.id}.${meta.lane}.rnaseq.transcriptome.post_dedup" }
        ext.emit_bed_counts  = true
        ext.emit_full_counts = false
        storeDir            = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/rnaseq/transcriptome', 'alignment_ribo').canonicalPath + '/' + (params.output?.individual_lane_directory ?: 'individual') }
    }

    // ── ribopy rnaseq set ─────────────────────────────────────────────────────────
    withName: RIBOPY_RNASEQ_SET {
        // storeDir caches the .updated.ribo intermediate; publishDir renames it to .ribo in the output dir
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/transcriptome', 'ribo_rnaseq').canonicalPath }
        publishDir = [ path: { new File((params.output?.output?.base ?: 'output'), (params.output?.output ?: [:]).getOrDefault('ribo', 'ribo')).canonicalPath },
                       mode: 'copy',
                       saveAs: { fn -> fn.replaceAll('\\.updated', '') } ]
    }
    withName: RIBOPY_MERGE {
        storeDir = { new File((params.output?.output?.base ?: 'output'), (params.output?.output ?: [:]).getOrDefault('ribo', 'ribo')).canonicalPath }
    }

    // ── RNA-seq genome stats ──────────────────────────────────────────────────────
    withName: '.*:RNASEQ_GENOME_STATS:RNASEQ_GENOME_STATS_INDIVIDUAL' {
        ext.stats_label = 'rnaseq_genome'
        ext.unique_only = { ((params.rnaseq?.genome?.mapping_quality_cutoff ?: params.rnaseq?.mapping_quality_cutoff ?: 4) as int) > 0 }
        storeDir = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/rnaseq', 'stats').canonicalPath + '/genome/individual' }
    }
    withName: '.*:RNASEQ_GENOME_STATS:RNASEQ_GENOME_COMBINE_INDIVIDUAL' {
        ext.prefix      = 'rnaseq_genome_individual_essential'
        ext.unique_only = { ((params.rnaseq?.genome?.mapping_quality_cutoff ?: params.rnaseq?.mapping_quality_cutoff ?: 4) as int) > 0 }
        storeDir        = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/rnaseq', 'stats').canonicalPath + '/genome/individual' }
    }
    withName: '.*:RNASEQ_GENOME_STATS:RNASEQ_GENOME_STATS_SUM' {
        ext.label             = 'rnaseq_genome'
        ext.use_merged_counts = { !((params.rnaseq?.dedup_method ?: 'none').toString().toLowerCase() == 'none') }
        ext.unique_only       = { ((params.rnaseq?.genome?.mapping_quality_cutoff ?: params.rnaseq?.mapping_quality_cutoff ?: 4) as int) >= 255 }
        storeDir = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/rnaseq', 'stats').canonicalPath + '/genome/merged' }
    }
    withName: '.*:RNASEQ_GENOME_STATS:RNASEQ_GENOME_COMBINE_MERGED' {
        ext.prefix      = 'rnaseq_genome_merged_essential'
        ext.unique_only = { ((params.rnaseq?.genome?.mapping_quality_cutoff ?: params.rnaseq?.mapping_quality_cutoff ?: 4) as int) > 0 }
        storeDir        = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/rnaseq', 'stats').canonicalPath + '/genome/merged' }
    }
    withName: '.*:RNASEQ_GENOME_STATS:RNASEQ_GENOME_STATS_PUBLISH' {
        publishDir = [ path: { new File((params.output?.output?.base ?: 'output') + '/rnaseq', (params.output?.output ?: [:]).getOrDefault('stats', 'stats')).canonicalPath + '/genome' }, mode: 'copy' ]
    }

    // ── RNA-seq transcriptome stats ───────────────────────────────────────────────
    withName: '.*:RNASEQ_TX_STATS:RNASEQ_TX_STATS_INDIVIDUAL' {
        ext.stats_label = 'rnaseq_transcriptome'
        storeDir = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/rnaseq', 'stats').canonicalPath + '/transcriptome/individual' }
    }
    withName: '.*:RNASEQ_TX_STATS:RNASEQ_TX_COMBINE_INDIVIDUAL' {
        ext.prefix      = 'rnaseq_transcriptome_individual_essential'
        ext.stats_label = 'transcriptome'
        storeDir        = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/rnaseq', 'stats').canonicalPath + '/transcriptome/individual' }
    }
    withName: '.*:RNASEQ_TX_STATS:RNASEQ_TX_STATS_SUM' {
        ext.label             = 'rnaseq_transcriptome'
        ext.use_merged_counts = false
        storeDir = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/rnaseq', 'stats').canonicalPath + '/transcriptome/merged' }
    }
    withName: '.*:RNASEQ_TX_STATS:RNASEQ_TX_COMBINE_MERGED' {
        ext.prefix      = 'rnaseq_transcriptome_merged_essential'
        ext.stats_label = 'transcriptome'
        storeDir        = { new File((params.output?.intermediates?.base ?: 'intermediates') + '/rnaseq', 'stats').canonicalPath + '/transcriptome/merged' }
    }
    withName: '.*:RNASEQ_TX_STATS:RNASEQ_TX_STATS_PUBLISH' {
        publishDir = [ path: { new File((params.output?.output?.base ?: 'output') + '/rnaseq', (params.output?.output ?: [:]).getOrDefault('stats', 'stats')).canonicalPath + '/transcriptome' }, mode: 'copy' ]
    }
}

// Per-module storeDir / publishDir / ext settings. Replaces the inline
// get_storedir()/get_publishdir() calls and per-process script differences of
// the DSL1 pipeline. Directory names are kept identical for parity.
//
// NOTE: config directive closures are evaluated in the task context, which does
// NOT have the lib/ classes on its classpath, so the path logic from
// lib/Utils.groovy is inlined here using only `params`. Shared modules (reused
// by the genome path and the optional transcriptome dedup subworkflow) are
// disambiguated with fully-qualified `.*:SUBWF:PROCESS` regex selectors.

process {

    // ── Preprocess ──────────────────────────────────────────────────────────
    withName: CUTADAPT_CLIP {
        storeDir = { new File((params.output?.intermediates?.base ?: 'intermediates'), (params.output?.intermediates ?: [:]).get('clip', 'clip')).canonicalPath }
    }
    withName: UMITOOLS_EXTRACT {
        storeDir = { new File((params.output?.intermediates?.base ?: 'intermediates'), (params.output?.intermediates ?: [:]).get('umi_tools', 'umi_tools')).canonicalPath + '/' + (params.output?.merged_lane_directory ?: 'merged') }
    }
    withName: BOWTIE2_FILTER {
        storeDir = { new File((params.output?.intermediates?.base ?: 'intermediates'), (params.output?.intermediates ?: [:]).get('filter', 'filter')).canonicalPath }
    }
    withName: RAW_FASTQC {
        ext.prefix = { "${meta.id}.${meta.lane}" }
        publishDir = [ path: { new File((params.output?.output?.base ?: 'output'), (params.output?.output ?: [:]).get('fastqc', 'fastqc')).canonicalPath + '/raw' }, mode: 'copy' ]
    }
    withName: CLIPPED_FASTQC {
        ext.prefix = { "${meta.id}.${meta.lane}.clipped" }
        publishDir = [ path: { new File((params.output?.output?.base ?: 'output'), (params.output?.output ?: [:]).get('fastqc', 'fastqc')).canonicalPath + '/clipped' }, mode: 'copy' ]
    }
    withName: GENOME_ALIGNED_FASTQC {
        ext.prefix = { "${meta.id}.${meta.lane}.genome.aligned" }
        publishDir = [ path: { new File((params.output?.output?.base ?: 'output'), (params.output?.output ?: [:]).get('fastqc', 'fastqc')).canonicalPath + '/genome_aligned' }, mode: 'copy' ]
    }
    withName: GENOME_UNALIGNED_FASTQC {
        ext.prefix = { "${meta.id}.${meta.lane}.genome.unaligned" }
        publishDir = [ path: { new File((params.output?.output?.base ?: 'output'), (params.output?.output ?: [:]).get('fastqc', 'fastqc')).canonicalPath + '/genome_unaligned' }, mode: 'copy' ]
    }

    // ── Genome alignment + qpass + per-lane BED ───────────────────────────────
    withName: STAR_ALIGN {
        storeDir = { new File((params.output?.intermediates?.base ?: 'intermediates'), (params.output?.intermediates ?: [:]).get('genome_alignment', 'genome_alignment')).canonicalPath + '/' + (params.output?.individual_lane_directory ?: 'individual') }
    }
    withName: '.*:GENOME_ALIGN:SAMTOOLS_QPASS' {
        ext.prefix = { "${meta.id}.${meta.lane}.genome_alignment" }
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates'), (params.output?.intermediates ?: [:]).get('quality_filter', 'quality_filter')).canonicalPath }
    }
    withName: '.*:GENOME_ALIGN:BAM_TO_BED' {
        ext.prefix = { "${meta.id}.${meta.lane}.genome.qpass" }
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates'), (params.output?.intermediates ?: [:]).get('bam_to_bed', 'bam_to_bed')).canonicalPath + '/' + (params.output?.individual_lane_directory ?: 'individual') }
        publishDir = [ path: { new File((params.output?.output?.base ?: 'output'), (params.output?.output ?: [:]).get('alignments', 'alignments')).canonicalPath + '/ribo/' + (params.output?.individual_lane_directory ?: 'individual') },
                       mode: 'copy', enabled: { (params.dedup_method ?: 'none').toString().toLowerCase() == 'none' && (params.deduplicate ?: false).toString().toLowerCase() == 'false' } ]
    }
    withName: '.*:GENOME_ALIGN:SAMTOOLS_MERGE' {
        ext.prefix = { "${meta.id}.genome.qpass.merged" }
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates'), (params.output?.intermediates ?: [:]).get('genome_alignment', 'genome_alignment')).canonicalPath + '/' + (params.output?.merged_lane_directory ?: 'merged') }
        publishDir = [ path: { new File((params.output?.output?.base ?: 'output'), (params.output?.output ?: [:]).get('alignments', 'alignments')).canonicalPath + '/ribo/' + (params.output?.merged_lane_directory ?: 'merged') },
                       mode: 'copy', enabled: { (params.dedup_method ?: 'none').toString().toLowerCase() == 'none' && (params.deduplicate ?: false).toString().toLowerCase() == 'false' } ]
    }

    // ── Position dedup (genome) ───────────────────────────────────────────────
    withName: ADD_SAMPLE_INDEX_COL {
        storeDir = { new File((params.output?.intermediates?.base ?: 'intermediates'), (params.output?.intermediates ?: [:]).get('bam_to_bed', 'bam_to_bed')).canonicalPath + '/' + (params.output?.individual_lane_directory ?: 'individual') }
    }
    withName: MERGE_PRE_DEDUP_BED {
        ext.prefix = { "${meta.id}.genome.merged.pre_dedup" }
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates'), (params.output?.intermediates ?: [:]).get('bam_to_bed', 'bam_to_bed')).canonicalPath + '/' + (params.output?.merged_lane_directory ?: 'merged') }
    }
    withName: '.*:GENOME_ALIGN:RFC_DEDUP' {
        ext.prefix = { "${meta.id}.genome" }
        storeDir   = { new File((params.output?.output?.base ?: 'output'), (params.output?.output ?: [:]).get('alignments', 'alignments')).canonicalPath + '/ribo/' + (params.output?.merged_lane_directory ?: 'merged') }
    }
    withName: '.*:GENOME_ALIGN:SEPARATE_BED' {
        ext.prefix      = { "${meta.id}.${meta.lane}.genome" }
        ext.emit_counts = true
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates'), (params.output?.intermediates ?: [:]).get('alignment_ribo', 'alignment_ribo')).canonicalPath + '/' + (params.output?.individual_lane_directory ?: 'individual') }
        publishDir = [ path: { new File((params.output?.output?.base ?: 'output'), (params.output?.output ?: [:]).get('alignments', 'alignments')).canonicalPath + '/ribo/' + (params.output?.individual_lane_directory ?: 'individual') },
                       mode: 'copy', saveAs: { fn -> fn.endsWith('.count') ? null : fn } ]
    }
    withName: '.*:GENOME_ALIGN:RFC_EXTRACT_DEDUP_READS' {
        ext.prefix      = { "${meta.id}.post_dedup" }
        ext.emit_counts = true
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates'), (params.output?.intermediates ?: [:]).get('alignment_ribo', 'alignment_ribo')).canonicalPath + '/' + (params.output?.merged_lane_directory ?: 'merged') }
        publishDir = [ path: { new File((params.output?.output?.base ?: 'output'), (params.output?.output ?: [:]).get('alignments', 'alignments')).canonicalPath + '/ribo/' + (params.output?.merged_lane_directory ?: 'merged') },
                       mode: 'copy', saveAs: { fn -> fn.endsWith('.count') ? null : fn } ]
    }

    // ── umicollapse dedup (genome) ────────────────────────────────────────────
    withName: '.*:GENOME_ALIGN:UMICOLLAPSE_DEDUP' {
        ext.prefix      = { "${meta.id}.dedup" }
        ext.emit_counts = true
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates'), (params.output?.intermediates ?: [:]).get('alignment_ribo', 'alignment_ribo')).canonicalPath + '/' + (params.output?.merged_lane_directory ?: 'merged') }
        publishDir = [ path: { new File((params.output?.output?.base ?: 'output'), (params.output?.output ?: [:]).get('alignments', 'alignments')).canonicalPath + '/ribo/' + (params.output?.merged_lane_directory ?: 'merged') },
                       mode: 'copy', saveAs: { fn -> fn.endsWith('.count') ? null : fn } ]
    }
    withName: '.*:GENOME_ALIGN:SPLIT_DEDUP_BAM' {
        ext.prefix          = { "${meta.id}.${meta.lane}.post_dedup" }
        ext.emit_bed_counts = true
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates'), (params.output?.intermediates ?: [:]).get('alignment_ribo', 'alignment_ribo')).canonicalPath + '/' + (params.output?.individual_lane_directory ?: 'individual') }
        publishDir = [ path: { new File((params.output?.output?.base ?: 'output'), (params.output?.output ?: [:]).get('alignments', 'alignments')).canonicalPath + '/ribo/' + (params.output?.individual_lane_directory ?: 'individual') },
                       mode: 'copy', saveAs: { fn -> fn.endsWith('.count') ? null : fn } ]
    }
    withName: CONCAT_POST_DEDUP_BED {
        ext.prefix = { "${meta.id}.genome.post_dedup" }
        storeDir   = { new File((params.output?.output?.base ?: 'output'), (params.output?.output ?: [:]).get('alignments', 'alignments')).canonicalPath + '/ribo/' + (params.output?.merged_lane_directory ?: 'merged') }
    }

    // ── none: publish merged qpass BED ────────────────────────────────────────
    withName: CONCAT_QPASS_BED_NONE {
        ext.prefix = { "${meta.id}.genome.qpass" }
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates'), (params.output?.intermediates ?: [:]).get('bam_to_bed', 'bam_to_bed')).canonicalPath + '/' + (params.output?.merged_lane_directory ?: 'merged') }
        publishDir = [ path: { new File((params.output?.output?.base ?: 'output'), (params.output?.output ?: [:]).get('alignments', 'alignments')).canonicalPath + '/ribo/' + (params.output?.merged_lane_directory ?: 'merged') },
                       mode: 'copy' ]
    }

    // ── bigwig + stranded split ───────────────────────────────────────────────
    withName: DEEPTOOLS_BAMCOVERAGE {
        storeDir = { new File((params.output?.output?.base ?: 'output'), (params.output?.output ?: [:]).get('bigwigs', 'bigwigs')).canonicalPath + '/ribo' }
    }
    withName: SPLIT_STRANDED_BAM {
        storeDir = { new File((params.output?.output?.base ?: 'output'), (params.output?.output ?: [:]).get('alignments', 'alignments')).canonicalPath + '/ribo/stranded' }
    }

    // ── Stats ─────────────────────────────────────────────────────────────────
    withName: STATS_INDIVIDUAL {
        storeDir = { new File((params.output?.intermediates?.base ?: 'intermediates'), (params.output?.intermediates ?: [:]).get('stats', 'stats')).canonicalPath + '/genome/individual' }
    }
    withName: COMBINE_INDIVIDUAL {
        ext.prefix = 'genome_individual_essential'
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates'), (params.output?.intermediates ?: [:]).get('stats', 'stats')).canonicalPath + '/genome/individual' }
    }
    withName: STATS_SUM {
        ext.use_merged_counts = { !((params.dedup_method ?: 'none').toString().toLowerCase() == 'none' && (params.deduplicate ?: false).toString().toLowerCase() == 'false') }
        storeDir = { new File((params.output?.intermediates?.base ?: 'intermediates'), (params.output?.intermediates ?: [:]).get('stats', 'stats')).canonicalPath + '/genome/merged' }
    }
    withName: COMBINE_MERGED {
        ext.prefix = 'genome_merged_essential'
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates'), (params.output?.intermediates ?: [:]).get('stats', 'stats')).canonicalPath + '/genome/merged' }
    }
    withName: STATS_PUBLISH {
        publishDir = [ path: { new File((params.output?.output?.base ?: 'output'), (params.output?.output ?: [:]).get('stats', 'stats')).canonicalPath }, mode: 'copy' ]
    }
    withName: WRITE_CORRESPONDENCE {
        publishDir = [ path: { new File((params.output?.output?.base ?: 'output'), (params.output?.output ?: [:]).get('stats', 'stats')).canonicalPath }, mode: 'copy' ]
    }

    // ── Optional transcriptome dedup subworkflow (BAM/BED only) ───────────────
    withName: '.*:STAR_TRANSCRIPTOME_DEDUP:SAMTOOLS_QPASS' {
        ext.prefix  = { "${meta.id}.${meta.lane}.transcriptome_alignment" }
        ext.presort = true
        storeDir    = { new File((params.output?.intermediates?.base ?: 'intermediates'), (params.output?.intermediates ?: [:]).get('transcriptome_alignment', 'transcriptome_alignment')).canonicalPath + '/' + (params.output?.individual_lane_directory ?: 'individual') }
    }
    withName: '.*:STAR_TRANSCRIPTOME_DEDUP:BAM_TO_BED' {
        ext.prefix       = { "${meta.id}.${meta.lane}.transcriptome.with_sample_index" }
        ext.append_index = true
        storeDir         = { new File((params.output?.intermediates?.base ?: 'intermediates'), (params.output?.intermediates ?: [:]).get('transcriptome_alignment', 'transcriptome_alignment')).canonicalPath + '/' + (params.output?.individual_lane_directory ?: 'individual') }
    }
    withName: '.*:STAR_TRANSCRIPTOME_DEDUP:CONCAT_SORT_BED' {
        ext.prefix = { "${meta.id}.transcriptome.merged.pre_dedup" }
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates'), (params.output?.intermediates ?: [:]).get('transcriptome_alignment', 'transcriptome_alignment')).canonicalPath + '/' + (params.output?.merged_lane_directory ?: 'merged') }
    }
    withName: '.*:STAR_TRANSCRIPTOME_DEDUP:RFC_DEDUP' {
        ext.prefix = { "${meta.id}.transcriptome" }
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates'), (params.output?.intermediates ?: [:]).get('transcriptome_alignment', 'transcriptome_alignment')).canonicalPath + '/' + (params.output?.merged_lane_directory ?: 'merged') }
    }
    withName: '.*:STAR_TRANSCRIPTOME_DEDUP:SEPARATE_BED' {
        ext.prefix = { "${meta.id}.${meta.lane}.transcriptome" }
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates'), (params.output?.intermediates ?: [:]).get('transcriptome_alignment', 'transcriptome_alignment')).canonicalPath + '/' + (params.output?.individual_lane_directory ?: 'individual') }
    }
    withName: '.*:STAR_TRANSCRIPTOME_DEDUP:SAMTOOLS_MERGE' {
        ext.prefix = { "${meta.id}.transcriptome.qpass.merged" }
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates'), (params.output?.intermediates ?: [:]).get('transcriptome_alignment', 'transcriptome_alignment')).canonicalPath + '/' + (params.output?.merged_lane_directory ?: 'merged') }
    }
    withName: '.*:STAR_TRANSCRIPTOME_DEDUP:RFC_EXTRACT_DEDUP_READS' {
        ext.prefix = { "${meta.id}.transcriptome.post_dedup" }
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates'), (params.output?.intermediates ?: [:]).get('transcriptome_alignment', 'transcriptome_alignment')).canonicalPath + '/' + (params.output?.merged_lane_directory ?: 'merged') }
    }
    withName: '.*:STAR_TRANSCRIPTOME_DEDUP:UMICOLLAPSE_DEDUP' {
        ext.prefix = { "${meta.id}.transcriptome.dedup" }
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates'), (params.output?.intermediates ?: [:]).get('transcriptome_alignment', 'transcriptome_alignment')).canonicalPath + '/' + (params.output?.merged_lane_directory ?: 'merged') }
    }
    withName: '.*:STAR_TRANSCRIPTOME_DEDUP:SPLIT_DEDUP_BAM' {
        ext.prefix = { "${meta.id}.${meta.lane}.transcriptome.post_dedup" }
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates'), (params.output?.intermediates ?: [:]).get('transcriptome_alignment', 'transcriptome_alignment')).canonicalPath + '/' + (params.output?.merged_lane_directory ?: 'merged') }
    }

    // ── Bowtie2 transcriptome alignment → ribopy create (.ribo) ──────────────
    withName: 'BOWTIE2_TRANSCRIPTOME' {
        storeDir = { new File((params.output?.intermediates?.base ?: 'intermediates'), (params.output?.intermediates ?: [:]).get('transcriptome_alignment', 'transcriptome_alignment')).canonicalPath + '/' + (params.output?.individual_lane_directory ?: 'individual') }
    }
    withName: '.*:TRANSCRIPTOME_ALIGN:SAMTOOLS_QPASS' {
        ext.prefix  = { "${meta.id}.${meta.lane}.transcriptome_alignment" }
        ext.presort = false
        ext.mapq    = { (params.transcriptome?.mapping_quality_cutoff != null) ? params.transcriptome.mapping_quality_cutoff : 10 }
        storeDir    = { new File((params.output?.intermediates?.base ?: 'intermediates'), (params.output?.intermediates ?: [:]).get('transcriptome_alignment', 'transcriptome_alignment')).canonicalPath + '/' + (params.output?.individual_lane_directory ?: 'individual') }
    }
    withName: '.*:TRANSCRIPTOME_ALIGN:SAMTOOLS_MERGE' {
        ext.prefix = { "${meta.id}.transcriptome.qpass.merged" }
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates'), (params.output?.intermediates ?: [:]).get('transcriptome_alignment', 'transcriptome_alignment')).canonicalPath + '/' + (params.output?.merged_lane_directory ?: 'merged') }
    }
    withName: '.*:TRANSCRIPTOME_ALIGN:TX_QPASS_BAM_TO_BED' {
        ext.prefix       = { "${meta.id}.${meta.lane}.transcriptome.with_sample_index" }
        ext.append_index = true
        storeDir         = { new File((params.output?.intermediates?.base ?: 'intermediates'), (params.output?.intermediates ?: [:]).get('transcriptome_alignment', 'transcriptome_alignment')).canonicalPath + '/' + (params.output?.individual_lane_directory ?: 'individual') }
    }
    withName: '.*:TRANSCRIPTOME_ALIGN:TX_MERGED_QPASS_BED' {
        ext.prefix = { "${meta.id}.transcriptome.qpass.merged" }
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates'), (params.output?.intermediates ?: [:]).get('transcriptome_alignment', 'transcriptome_alignment')).canonicalPath + '/' + (params.output?.merged_lane_directory ?: 'merged') }
    }
    withName: '.*:TRANSCRIPTOME_ALIGN:TX_MERGED_DEDUP_BED' {
        ext.prefix = { "${meta.id}.transcriptome.dedup" }
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates'), (params.output?.intermediates ?: [:]).get('transcriptome_alignment', 'transcriptome_alignment')).canonicalPath + '/' + (params.output?.merged_lane_directory ?: 'merged') }
    }
    withName: '.*:TRANSCRIPTOME_ALIGN:MERGE_TX_PRE_DEDUP_BED' {
        ext.prefix = { "${meta.id}.transcriptome.merged.pre_dedup" }
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates'), (params.output?.intermediates ?: [:]).get('transcriptome_alignment', 'transcriptome_alignment')).canonicalPath + '/' + (params.output?.merged_lane_directory ?: 'merged') }
    }
    withName: '.*:TRANSCRIPTOME_ALIGN:RFC_DEDUP' {
        ext.prefix = { "${meta.id}.transcriptome" }
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates'), (params.output?.intermediates ?: [:]).get('transcriptome_alignment', 'transcriptome_alignment')).canonicalPath + '/' + (params.output?.merged_lane_directory ?: 'merged') }
    }
    withName: '.*:TRANSCRIPTOME_ALIGN:SEPARATE_BED' {
        ext.prefix = { "${meta.id}.${meta.lane}.transcriptome" }
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates'), (params.output?.intermediates ?: [:]).get('transcriptome_alignment', 'transcriptome_alignment')).canonicalPath + '/' + (params.output?.individual_lane_directory ?: 'individual') }
    }
    withName: '.*:TRANSCRIPTOME_ALIGN:RFC_EXTRACT_DEDUP_READS' {
        ext.prefix = { "${meta.id}.transcriptome.post_dedup" }
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates'), (params.output?.intermediates ?: [:]).get('transcriptome_alignment', 'transcriptome_alignment')).canonicalPath + '/' + (params.output?.merged_lane_directory ?: 'merged') }
    }
    withName: '.*:TRANSCRIPTOME_ALIGN:UMICOLLAPSE_DEDUP' {
        ext.prefix = { "${meta.id}.transcriptome.dedup" }
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates'), (params.output?.intermediates ?: [:]).get('transcriptome_alignment', 'transcriptome_alignment')).canonicalPath + '/' + (params.output?.merged_lane_directory ?: 'merged') }
    }
    withName: '.*:TRANSCRIPTOME_ALIGN:SPLIT_DEDUP_BAM' {
        ext.prefix = { "${meta.id}.${meta.lane}.transcriptome.post_dedup" }
        storeDir   = { new File((params.output?.intermediates?.base ?: 'intermediates'), (params.output?.intermediates ?: [:]).get('transcriptome_alignment', 'transcriptome_alignment')).canonicalPath + '/' + (params.output?.individual_lane_directory ?: 'individual') }
    }
    withName: 'RIBOPY_CREATE' {
        publishDir = [ path: { new File((params.output?.output?.base ?: 'output'), (params.output?.output ?: [:]).get('ribo', 'ribo')).canonicalPath },
                       mode: 'copy' ]
    }
}

// Minimal config for a stub wiring check of the whole genome DAG:
//   nextflow run main.nf -stub-run -profile test
// Override the dedup branch with e.g. `--dedup_method umicollapse` / `none`.

includeConfig 'local.config'

params {
    do_check_file_existence = false
    do_fastqc               = false
    do_rnaseq               = false
    do_strand_split         = true

    dedup_method                = 'position'
    umi_tools_extract_arguments = ''
    umicollapse_arguments       = ''

    mapping_quality_cutoff = 255
    ribo_filter_flags      = 2308
    clip_arguments         = '-u 1 -a CTGTAGGCACCATCAAT --overlap=4 --trimmed-only --maximum-length=40 --minimum-length=15 --quality-cutoff=28'

    alignment_arguments = [ filter: '-L 15 --no-unal --norc', genome: '' ]
    star = [ output_transcriptome_bam: false,
             ribo_arguments: '--alignEndsType EndToEnd --twopassMode Basic' ]

    input = [
        reference: [ filter: "${projectDir}/tests/stub/filter/human_rtRNA*",
                     genome: "${projectDir}/tests/stub/genome" ],
        fastq_base: '',
        fastq: [ S1: ["${projectDir}/tests/stub/fastq/S1.l1.fastq.gz",
                      "${projectDir}/tests/stub/fastq/S1.l2.fastq.gz"],
                 S2: ["${projectDir}/tests/stub/fastq/S2.l1.fastq.gz"] ]
    ]

    output = [
        individual_lane_directory: 'individual',
        merged_lane_directory:     'merged',
        intermediates: [ base: "${projectDir}/tests/stub/work_intermediates" ],
        output:        [ base: "${projectDir}/tests/stub/work_output" ]
    ]
}

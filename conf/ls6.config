// Resource budget for a TACC LS6 compute node (128 cores, 256 GB RAM).
// Use with: -profile conda,ls6  |  -profile apptainer,ls6  |  -profile docker,ls6
//
// Thread/maxFork caps follow the original configs/local.config rationale:
// STAR holds ~30 GB in shared memory; UMICOLLAPSE JVM claims 32 GB heap.

process {
    executor = 'local'

    withName: CUTADAPT_CLIP {
        cpus   = 32
        memory = '16.GB'
    }

    // bowtie2 caps at 16 threads, samtools sort at 8 (see module). maxForks=2
    // prevents several bowtie2+sort pipes competing for ~16 GB each.
    withName: BOWTIE2_FILTER {
        cpus     = 32
        memory   = '16.GB'
        maxForks = 2
    }

    // STAR index generation: human genome requires ~30 GB RAM; 64 GB headroom for safety.
    withName: STAR_INDEX {
        cpus     = 32
        memory   = '64.GB'
        maxForks = 1
    }

    // STAR loads the genome index in RAM (~30 GB) plus working memory.
    withName: STAR_ALIGN {
        cpus     = 64
        memory   = '64.GB'
        maxForks = 1
    }

    withName: STAR_ALIGN_RNASEQ {
        cpus     = 64
        memory   = '64.GB'
        maxForks = 1
    }

    // bamCoverage forks N python workers; the module caps -p at min(cpus,8).
    withName: DEEPTOOLS_BAMCOVERAGE {
        cpus     = 8
        memory   = '16.GB'
        maxForks = 2
    }

    // umicollapse JVM: 32 GB heap + ~8 GB overhead. maxForks=1 — two -Xmx32g
    // JVMs OOM a node that already has STAR/bigwig/filter forks resident.
    // algo=cc: TACC caps the process stack hard limit so --algo dir (recursive DFS)
    // stack-overflows on large UMI graphs; cc uses iterative union-find instead.
    withName: UMICOLLAPSE_DEDUP {
        cpus     = 8
        memory   = '40.GB'
        maxForks = 1
        ext.algo = 'cc'
    }

    // ── Optional transcriptome-dedup subworkflow overrides ──────────────────
    withName: 'STAR_TRANSCRIPTOME_DEDUP:SAMTOOLS_QPASS' {
        cpus   = 16
        memory = '32.GB'
    }
    withName: 'STAR_TRANSCRIPTOME_DEDUP:SAMTOOLS_MERGE' {
        cpus   = 32
        memory = '32.GB'
    }
    withName: 'STAR_TRANSCRIPTOME_DEDUP:SPLIT_DEDUP_BAM' {
        cpus   = 8
        memory = '16.GB'
    }
    withName: 'STAR_TRANSCRIPTOME_DEDUP:RFC_EXTRACT_DEDUP_READS' {
        cpus   = 8
        memory = '16.GB'
    }
}

// Reserve ~16 GB for OS / Nextflow JVM; give 240 GB to tasks.
executor {
    cpus   = 128
    memory = '240.GB'
}

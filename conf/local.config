// Local-executor resource budget for the genome (ribo-seq) path.
//
// Sized for a TACC LS6 compute node (128 cores, 256 GB RAM). See the original
// configs/local.config for the full memory-accounting rationale; the same
// thread/maxFork caps apply here. Per-process selectors use the DSL2 module
// process names; tool-specific overrides for the optional transcriptome-dedup
// subworkflow use fully-qualified selectors so they don't disturb the genome
// path that reuses the same modules.

process {
    executor = 'local'

    withName: CUTADAPT_CLIP {
        cpus   = 32
        memory = '16.GB'
    }

    // bowtie2 caps at 16 threads, samtools sort at 8 (see module). maxForks=2
    // prevents several bowtie2+sort pipes competing for ~16 GB each.
    withName: BOWTIE2_FILTER {
        cpus     = 32
        memory   = '16.GB'
        maxForks = 2
    }

    // STAR loads the genome index in RAM (~30 GB) plus 2-pass working memory.
    withName: STAR_ALIGN {
        cpus     = 64
        memory   = '64.GB'
        maxForks = 1
    }

    // bamCoverage forks N python workers; the module caps -p at min(cpus,8).
    withName: DEEPTOOLS_BAMCOVERAGE {
        cpus     = 8
        memory   = '16.GB'
        maxForks = 2
    }

    // umicollapse JVM: 32 GB heap + ~8 GB overhead. maxForks=1 — two -Xmx32g
    // JVMs OOM a node that already has STAR/bigwig/filter forks resident.
    withName: UMICOLLAPSE_DEDUP {
        cpus     = 8
        memory   = '40.GB'
        maxForks = 1
    }

    // ── Optional transcriptome-dedup subworkflow overrides ──────────────────
    withName: 'STAR_TRANSCRIPTOME_DEDUP:SAMTOOLS_QPASS' {
        cpus   = 16
        memory = '32.GB'
    }
    withName: 'STAR_TRANSCRIPTOME_DEDUP:SAMTOOLS_MERGE' {
        cpus   = 32
        memory = '32.GB'
    }
    withName: 'STAR_TRANSCRIPTOME_DEDUP:SPLIT_DEDUP_BAM' {
        cpus   = 8
        memory = '16.GB'
    }
    withName: 'STAR_TRANSCRIPTOME_DEDUP:RFC_EXTRACT_DEDUP_READS' {
        cpus   = 8
        memory = '16.GB'
    }
}

// Total CPUs/memory the local executor may use concurrently. On a 256 GB LS6
// node reserve ~16 GB for the OS / Nextflow JVM and give 240 GB to tasks.
executor {
    cpus   = 128
    memory = '240.GB'
}

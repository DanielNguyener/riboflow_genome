// Resource budget for a local workstation / laptop.
// Use with: -profile local  |  -profile conda,local  |  -profile apptainer,local  |  -profile docker,local
//
// Sized for 16 cores / 32 GB RAM. Adjust executor.cpus / executor.memory
// and the per-process values to match your machine.
// NOTE: STAR alignment requires ~30 GB RAM for a full human index. On a 32 GB
// machine run one sample at a time (maxForks=1) and close other applications.

process {
    executor = 'local'

    withName: CUTADAPT_CLIP {
        cpus   = 8
        memory = '4.GB'
    }

    withName: BOWTIE2_FILTER {
        cpus     = 8
        memory   = '4.GB'
        maxForks = 1
    }

    // STAR index generation: human genome requires ~30 GB RAM.
    withName: STAR_INDEX {
        cpus     = 16
        memory   = '30.GB'
        maxForks = 1
    }

    // STAR alignment loads the full genome index into RAM (~30 GB).
    withName: STAR_ALIGN {
        cpus     = 16
        memory   = '30.GB'
        maxForks = 1
    }

    withName: STAR_ALIGN_RNASEQ {
        cpus     = 16
        memory   = '30.GB'
        maxForks = 1
    }

    withName: DEEPTOOLS_BAMCOVERAGE {
        cpus     = 4
        memory   = '4.GB'
        maxForks = 1
    }

    withName: UMICOLLAPSE_DEDUP {
        cpus     = 4
        memory   = '8.GB'
        maxForks = 1
    }

    // ── Optional transcriptome-dedup subworkflow overrides ──────────────────
    withName: 'STAR_TRANSCRIPTOME_DEDUP:SAMTOOLS_QPASS' {
        cpus   = 4
        memory = '4.GB'
    }
    withName: 'STAR_TRANSCRIPTOME_DEDUP:SAMTOOLS_MERGE' {
        cpus   = 8
        memory = '8.GB'
    }
    withName: 'STAR_TRANSCRIPTOME_DEDUP:SPLIT_DEDUP_BAM' {
        cpus   = 4
        memory = '4.GB'
    }
    withName: 'STAR_TRANSCRIPTOME_DEDUP:RFC_EXTRACT_DEDUP_READS' {
        cpus   = 4
        memory = '4.GB'
    }
}

// Leave ~4 GB headroom for OS and other applications.
executor {
    cpus   = 16
    memory = '28.GB'
}

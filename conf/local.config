// Resource budget for a local workstation / laptop.
// Use with: -profile local  |  -profile conda,local  |  -profile apptainer,local  |  -profile docker,local
//
// Sized for 16 cores / 32 GB RAM. Adjust executor.cpus / executor.memory
// and the per-process values to match your machine.
//
// IMPORTANT: executor.memory must be >= the largest per-process `memory` below,
// or the local executor cannot schedule that task and aborts it (exit status
// `-`, empty output). STAR needs ~30 GB for a full human index, so the pool is
// set to the machine's full 32 GB — leaving no OS headroom. On a 32 GB machine
// run one sample at a time (maxForks=1, already set) and close other apps. With
// < 32 GB you cannot align a full human genome locally: use a larger node (see
// conf/ls6.config) or run without a resource profile so the executor
// auto-detects the node's full RAM.

process {
    executor = 'local'

    withName: CUTADAPT_CLIP {
        cpus   = 8
        memory = '4.GB'
    }

    withName: BOWTIE2_FILTER {
        cpus     = 8
        memory   = '4.GB'
        maxForks = 1
    }

    // STAR index generation: human genome requires ~30 GB RAM.
    withName: STAR_INDEX {
        cpus     = 16
        memory   = '30.GB'
        maxForks = 1
    }

    // STAR alignment loads the full genome index into RAM (~30 GB).
    withName: STAR_ALIGN {
        cpus     = 16
        memory   = '30.GB'
        maxForks = 1
    }

    withName: STAR_ALIGN_RNASEQ {
        cpus     = 16
        memory   = '30.GB'
        maxForks = 1
    }

    withName: DEEPTOOLS_BAMCOVERAGE {
        cpus     = 4
        memory   = '4.GB'
        maxForks = 1
    }

    withName: UMICOLLAPSE_DEDUP {
        cpus     = 4
        memory   = '8.GB'
        maxForks = 1
        ext.algo = 'cc'
    }

    // ── Optional transcriptome-dedup subworkflow overrides ──────────────────
    withName: 'STAR_TRANSCRIPTOME_DEDUP:SAMTOOLS_QPASS' {
        cpus   = 4
        memory = '4.GB'
    }
    withName: 'STAR_TRANSCRIPTOME_DEDUP:SAMTOOLS_MERGE' {
        cpus   = 8
        memory = '8.GB'
    }
    withName: 'STAR_TRANSCRIPTOME_DEDUP:SPLIT_DEDUP_BAM' {
        cpus   = 4
        memory = '4.GB'
    }
    withName: 'STAR_TRANSCRIPTOME_DEDUP:RFC_EXTRACT_DEDUP_READS' {
        cpus   = 4
        memory = '4.GB'
    }
}

// Full 32 GB so STAR's 30 GB request is schedulable (must be >= the largest
// per-process memory above). maxForks=1 on the heavy tasks prevents oversubscription.
executor {
    cpus   = 16
    memory = '32.GB'
}

config {
    // Location of nf-test test files.
    testsDir "tests"

    // nf-test working directory.
    workDir ".nf-test"

    // Base Nextflow config used for every test.
    configFile "nextflow.config"

    // All tests run against the stub-fixture profile by default.
    profile "test"

    // Wipe per-test work dirs on success to keep the tree small.
    autoSort false
}

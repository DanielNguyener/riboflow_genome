// RiboFlow (genome) — DSL2.
nextflow.enable.dsl = 2

manifest {
    name        = 'riboflow_genome_DSL2'
    homePage    = 'https://github.com/DanielNguyener/riboflow_genome_DSL2'
    description = 'Ribosome-profiling genome alignment pipeline (DSL2, nf-core layout).'
    mainScript  = 'main.nf'
    version     = '0.0.1'
}

// Pipeline-level parameter defaults. Test/example YAMLs override these.
params {
    genome = [
        run:                    true,   // set false to skip genome alignment (transcriptome.run must then be true)
        mapping_quality_cutoff: 255,    // STAR: 255=unique only; <255=include multi-mappers
        ribo_filter_flags:      2308    // 2308 = unmapped(4) + secondary(256) + supplementary(2048)
    ]

    transcriptome = [
        run:                    false,
        mapping_quality_cutoff: 10    // bowtie2: 10=confident; 20=more strict; 40=unique only
    ]

    // alignment_arguments.transcriptome default (same sensitivity as filter).
    // Override in example YAMLs or --alignment_arguments.transcriptome.
    alignment_arguments = [
        filter:        '-L 15 --no-unal --norc',
        genome:        '',
        transcriptome: '-L 15 --no-unal --norc'
    ]

    ribo = [
        ref_name:        'appris_human',
        metagene_radius: 50,
        left_span:       35,
        right_span:      15,
        read_length:     [ min: 15, max: 35 ],
        coverage:        true
    ]

    // STAR per-path arguments. ribo_arguments applies to the ribo-seq genome
    // alignment; rnaseq_arguments to the RNA-seq genome alignment. Override in
    // example YAMLs. Defaults are empty / ENCODE PE flags respectively.
    star = [
        output_transcriptome_bam: false,
        ribo_arguments:   '',
        rnaseq_arguments: '--outFilterType BySJout --outFilterMultimapNmax 20 --alignSJoverhangMin 8 --alignSJDBoverhangMin 1 --outFilterMismatchNmax 999 --outFilterMismatchNoverReadLmax 0.04 --alignIntronMin 20 --alignIntronMax 1000000 --alignMatesGapMax 1000000'
    ]

    // RNA-seq path (off by default). Separate FASTQs, clip/filter/dedup params
    // from the ribo-seq path; shares the bowtie2 filter + genome/transcriptome refs.
    do_rnaseq = false

    rnaseq = [
        fastq_base:                  '',
        clip_arguments:              '-u 1 --quality-cutoff=28 --minimum-length=20',
        filter_arguments:            '-L 15 --no-unal',
        dedup_method:                'none',
        umi_tools_extract_arguments: '',
        genome:       [ mapping_quality_cutoff: 4,  filter_flags: 2308 ],
        transcriptome:[ mapping_quality_cutoff: 10, alignment_arguments: '-L 15 --no-unal' ]
    ]
}

// Default process settings. Per-tool resources live in conf/local.config and
// per-module storeDir/publishDir/ext.args live in conf/modules.config.
includeConfig 'conf/base.config'
includeConfig 'conf/modules.config'

process.shell = ['/bin/bash', '-uexo', 'pipefail']

profiles {

    // Local execution. Assumes the `ribo_genome` conda env (environment.yaml)
    // is already on PATH — same assumption as the original pipeline's Docker
    // image / activated env. Combine with `conda` or `docker` to have Nextflow
    // manage the environment instead.
    standard {
        includeConfig 'conf/local.config'
    }

    // Let Nextflow build and manage the single consolidated conda env.
    conda {
        conda.enabled  = true
        conda.channels = ['conda-forge', 'bioconda']
        process.conda  = "${projectDir}/environment.yaml"
        includeConfig 'conf/local.config'
    }

    // Run every process inside the consolidated Docker image.
    docker {
        docker.enabled    = true
        docker.runOptions = '-u $(id -u):$(id -g)'
        process.container = 'danielnguyener/riboflow:0.0.2'
        includeConfig 'conf/local.config'
    }

    // Fast wiring check: stub-run the whole genome DAG with tiny fixtures.
    test {
        includeConfig 'conf/test.config'
    }
}

timeline { enabled = true; file = "./nextflow_logs/timeline.html"; overwrite = true }
trace    { enabled = true; file = "./nextflow_logs/trace.txt";    overwrite = true }
report   { enabled = true; file = "./nextflow_logs/report.html";  overwrite = true }
